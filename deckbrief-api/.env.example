# Postgres connection string (Railway injects this automatically)
DATABASE_URL=postgresql://user:password@host:5432/deckbrief

# Anthropic — Claude Haiku for follow-up drafts + daily brief
ANTHROPIC_API_KEY=sk-ant-...

# Resend — transactional email
RESEND_API_KEY=re_...

# MASTER platform key — super-admin. Manages accounts (/api/admin/*) and
# sees ALL accounts' data on every protected route. Generate: openssl rand -hex 32
# Per-customer account keys (dbk_...) are created via POST /api/admin/accounts.
API_SECRET_KEY=replace-with-long-random-string

# Where to send the 7AM brief and lead notifications
BRIEF_RECIPIENT_EMAIL=chapmancapital1@gmail.com

# Express port (Railway sets PORT automatically)
PORT=3000
